<!DOCTYPE html>
<html lang="ru">
  <head>
    {{> head}}
  </head>
  <body>
    <div class="shell">
      <div class="topbar">
        <span class="brand">{{title}}</span>
        <nav class="nav">
          <span class="text-muted">{{userLogin}}</span>
          <a href="/api-docs" target="_blank" rel="noopener">Swagger</a>
          <a href="/logout">Выйти</a>
        </nav>
      </div>

      <div class="panel">
        <h2>Бронирования</h2>
        {{#if bookings.length}}
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Дата</th>
                <th>Гости</th>
                <th>Контакт</th>
                <th>Стол / зал</th>
                <th>Создано</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="bookings-tbody">
              {{#each bookings}}
                <tr data-booking-row="{{this.id}}">
                  <td>{{this.id}}</td>
                  <td>{{this.visitDate}}</td>
                  <td>{{this.guestCount}}</td>
                  <td>
                    {{this.contactName}}<br />
                    <span class="text-muted">{{this.contactPhone}}</span>
                    {{#if this.contactEmail}}<br /><span class="text-muted">{{this.contactEmail}}</span>{{/if}}
                  </td>
                  <td>{{this.tableCode}} — {{this.hallName}}</td>
                  <td>{{this.createdAtDisplay}}</td>
                  <td>
                    <button type="button" class="js-delete-booking" data-booking-id="{{this.id}}">Удалить</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        {{else}}
          <p class="empty">Нет бронирований.</p>
        {{/if}}
      </div>

      <div class="panel">
        <h2>Отзывы</h2>
        {{#if reviews.length}}
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Блюдо</th>
                <th>Автор</th>
                <th>Текст</th>
                <th>Создано</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="reviews-tbody">
              {{#each reviews}}
                <tr data-review-row="{{this.id}}">
                  <td>{{this.id}}</td>
                  <td>{{this.dishName}} <span class="text-muted">(#{{this.dishId}})</span></td>
                  <td>{{this.authorName}}</td>
                  <td class="review-body">{{this.body}}</td>
                  <td>{{this.createdAtDisplay}}</td>
                  <td>
                    <button type="button" class="js-delete-review" data-review-id="{{this.id}}">Удалить</button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        {{else}}
          <p class="empty">Нет отзывов.</p>
        {{/if}}
      </div>
    </div>
    <script>
      (function () {
        var ADMIN_ACCESS_TOKEN = {{{accessTokenJson}}};

        function apiFetch(path, options) {
          if (typeof ADMIN_ACCESS_TOKEN !== 'string' || !ADMIN_ACCESS_TOKEN) {
            window.location.href = '/login';
            return Promise.reject(new Error('no token'));
          }
          var headers = Object.assign({}, (options && options.headers) || {}, {
            Authorization: 'Bearer ' + ADMIN_ACCESS_TOKEN,
          });
          return fetch('/api' + path, Object.assign({}, options || {}, { headers: headers })).then(function (res) {
            if (res.status === 401) {
              window.location.href = '/login';
              throw new Error('unauthorized');
            }
            return res;
          });
        }

        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('.js-delete-booking').forEach(function (button) {
            button.addEventListener('click', function () {
              var id = button.getAttribute('data-booking-id');
              if (!id || !confirm('Удалить бронирование #' + id + '?')) return;
              apiFetch('/admin/bookings/' + id, { method: 'DELETE' })
                .then(function (res) {
                  if (!res.ok) throw new Error('delete failed');
                  var row = document.querySelector('[data-booking-row="' + id + '"]');
                  if (row) row.remove();
                })
                .catch(function () {
                  alert('Не удалось удалить бронирование.');
                });
            });
          });

          document.querySelectorAll('.js-delete-review').forEach(function (button) {
            button.addEventListener('click', function () {
              var id = button.getAttribute('data-review-id');
              if (!id || !confirm('Удалить отзыв #' + id + '?')) return;
              apiFetch('/admin/reviews/' + id, { method: 'DELETE' })
                .then(function (res) {
                  if (!res.ok) throw new Error('delete failed');
                  var row = document.querySelector('[data-review-row="' + id + '"]');
                  if (row) row.remove();
                })
                .catch(function () {
                  alert('Не удалось удалить отзыв.');
                });
            });
          });
        });
      })();
    </script>
  </body>
</html>

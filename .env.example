# Local Postgres (host machine)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/istu_dwa_lb_2

# In Docker Compose the api service sets DATABASE_URL to host `db` automatically.
# Schema is applied by Postgres init (docker-entrypoint-initdb.d), not by the API container.
# Without Docker, run: npm run db:migrate
# PORT defaults to 3000.
